# DSOA GitHub Actions deployment workflow
# Generated by: ./scripts/deploy/deploy.sh --env=ENV --interactive --ci-export=github
#
# Setup instructions: see GITHUB_SECRETS_SETUP.md (generated alongside this file)
#
# Usage:
#   1. Copy this file to .github/workflows/ in your deployment repository
#   2. Configure secrets listed in GITHUB_SECRETS_SETUP.md
#   3. Trigger via GitHub Actions UI → "Deploy DSOA to Snowflake"
#
# Supported scopes:
#   - all: Full installation (init, admin, setup, plugins, config, agents, apikey)
#   - init: Initialize database, schema, warehouse
#   - admin: Create roles and grants
#   - setup: Create helper objects
#   - plugins: Deploy plugin code
#   - config: Deploy configuration
#   - agents: Deploy agent procedures
#   - apikey: Update API key
#   - upgrade: Upgrade from previous version (requires from_version)
#   - teardown: Remove all DSOA objects

name: Deploy DSOA to Snowflake
on:
  workflow_dispatch:
    inputs:
      scope:
        description: "Deployment scope"
        required: true
        default: "all"
        type: choice
        options:
          - all
          - init
          - admin
          - setup
          - plugins
          - config
          - agents
          - apikey
          - upgrade
          - teardown
      from_version:
        description: "Upgrade from version (required when scope=upgrade)"
        required: false
        default: ""

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout deployment config
        uses: actions/checkout@v4

      - name: Deploy DSOA
        run: |
          docker run --rm \
            -v "${{ github.workspace }}/conf:/app/conf" \
            -e DTAGENT_TOKEN="${{ secrets.DTAGENT_TOKEN }}" \
            -e SNOWFLAKE_ACCOUNT="${{ secrets.SNOWFLAKE_ACCOUNT }}" \
            -e SNOWFLAKE_USER="${{ secrets.SNOWFLAKE_USER }}" \
            -e SNOWFLAKE_PRIVATE_KEY_RAW="${{ secrets.SNOWFLAKE_PRIVATE_KEY_RAW }}" \
            ghcr.io/dynatrace-oss/dsoa-deploy:__VERSION__ \
            --env=__ENV__ \
            --scope=${{ inputs.scope }} \
            ${{ inputs.from_version != '' && format('--from-version={0}', inputs.from_version) || '' }} \
            --defaults \
            --options=skip_confirm
